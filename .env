# ======================
# 币安实时基差监控配置
# ======================

# 目标币对（逗号分隔）
SYMBOLS=BTCUSDT,USDCUSDT,ETHUSDT,SOLUSDT,XRPUSDT,DOGEUSDT,USD1USDT,PAXGUSDT,BNBUSDT,SUIUSDT,ZECUSDT,ADAUSDT,FDUSDUSDT,PEPEUSDT,AVAXUSDT,OPNUSDT,NEARUSDT,LINKUSDT,TRXUSDT,TAOUSDT,UUSDT,FLOWUSDT,FILUSDT,PIXELUSDT,WLDUSDT,EURUSDT,LTCUSDT,SHIBUSDT,ROBOUSDT,XPLUSDT,PUMPUSDT,SIGNUSDT

# 数据桶间隔（秒）
WINDOW_INTERVAL=60

# 统计窗口长度
EMA_WINDOW=30

# WebSocket配置
WS_RECONNECT_INTERVAL=5
WS_TIMEOUT=30
WS_MAX_RETRIES=10

# 队列配置
QUEUE_MAX_SIZE=10000
QUEUE_WARNING_THRESHOLD=8000

# 性能监控
UI_REFRESH_INTERVAL=2
LOG_OUTPUT_INTERVAL=10
METRICS_OUTPUT_INTERVAL=60

# 日志级别
LOG_LEVEL=INFO
LOG_FILE=logs/py-basis.log
LOG_MAX_SIZE=100MB
LOG_BACKUP_COUNT=10

# 性能测试模式（true/false）
PERFORMANCE_TEST_MODE=false
TEST_SYMBOL_COUNT=50
TEST_DURATION_HOURS=24